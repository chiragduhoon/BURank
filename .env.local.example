# Copy to .env.local and fill in.

NEXT_PUBLIC_COLLEGE_NAME=Bennett University

# Database — SQLite locally, or a hosted Postgres URL in production
DATABASE_URL=file:./dev.db

# Email transport (pick one; if neither is set, dev mode shows the
# magic link directly on the sign-in page)
# GMAIL_USER=you@gmail.com
# GMAIL_APP_PASSWORD=your16charapppassword
# RESEND_API_KEY=re_your_key
EMAIL_FROM=noreply@example.com

# Auth
NEXTAUTH_SECRET=generate-a-long-random-string
NEXTAUTH_URL=http://localhost:3000

# Admin panel password (/admin)
ADMIN_PASSWORD=choose-a-strong-password
